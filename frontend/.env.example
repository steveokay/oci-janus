# Beacon — frontend environment.
# Copy to .env.local and adjust per environment. None of these are secrets;
# they only configure where the browser talks to.

# Base URL the SPA uses to reach the management API (BFF).
# In dev, Vite proxies this prefix to http://localhost:8091.
# In prod, nginx terminates this on the same host and proxies to registry-management:8085.
VITE_API_BASE_URL=/api/v1

# Base URL for the auth service (login, refresh, JWKS).
# In dev, Vite proxies /api/v1/login through the management API; refresh + logout go through the same path.
# Leave this matching VITE_API_BASE_URL unless your environment splits them.
VITE_AUTH_BASE_URL=/api/v1
