# Infrastructure + application services — copy to .env and fill in secrets.
# Never commit .env
#
# JWT keys for registry-auth: set in services/auth/.env (copy from services/auth/.env.example)
# OCI core extra config: set in services/core/.env (copy from services/core/.env.example)

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=registry

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=registry
RABBITMQ_DEFAULT_PASS=registry

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── registry-proxy ────────────────────────────────────────────────────────────
# 64-char hex key (32 bytes) for AES-256-GCM upstream credential encryption.
# Generate: openssl rand -hex 32
PROXY_CREDENTIAL_KEY_HEX=

# ── registry-webhook ─────────────────────────────────────────────────────────
# 64-char hex key (32 bytes) for encrypting HMAC webhook secrets at rest.
# Generate: openssl rand -hex 32
WEBHOOK_CREDENTIAL_KEY_HEX=

# ── registry-signer ───────────────────────────────────────────────────────────
# ECDSA P-256 key pair, base64-encoded PEM.
#
# Generate private key:
#   openssl ecparam -name prime256v1 -genkey -noout \
#     | openssl pkcs8 -topk8 -nocrypt \
#     | base64 -w0
#
# Derive public key from private key:
#   echo "$SIGNER_COSIGN_PRIVATE_KEY" | base64 -d \
#     | openssl pkey -pubout \
#     | base64 -w0
SIGNER_COSIGN_PRIVATE_KEY=
SIGNER_COSIGN_PUBLIC_KEY=

# ── registry-scanner (optional profile) ──────────────────────────────────────
# Start scanner: docker compose --profile scanner up -d registry-scanner
#
# Absolute path inside the container to the scanner plugin binary:
SCANNER_PLUGIN_PATH=
# SHA-256 hex checksum of the plugin binary (sha256sum <binary> | cut -d' ' -f1):
SCANNER_PLUGIN_CHECKSUM=
