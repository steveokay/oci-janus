# --- Server ---
GRPC_ADDR=:50051
HTTP_ADDR=:8080
LOG_LEVEL=info
LOG_FORMAT=json

# --- mTLS — production fail-safe (REDESIGN-001 Q-004 / Phase 1.2). Set to "false" only in local dev. ---
MTLS_REQUIRED=true
MTLS_CA_CERT_PATH=/certs/ca.crt
MTLS_CERT_PATH=/certs/storage.crt
MTLS_KEY_PATH=/certs/storage.key

# --- Storage driver (required: minio|s3|gcs|azure|filesystem) ---
STORAGE_DRIVER=minio

# MinIO
STORAGE_MINIO_ENDPOINT=minio:9000
STORAGE_MINIO_ACCESS_KEY=
STORAGE_MINIO_SECRET_KEY=
STORAGE_MINIO_BUCKET=registry
STORAGE_MINIO_USE_SSL=true

# AWS S3
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=

# GCS
STORAGE_GCS_BUCKET=
STORAGE_GCS_PROJECT=

# Azure
STORAGE_AZURE_CONTAINER=
STORAGE_AZURE_ACCOUNT=

# Filesystem (dev only)
STORAGE_FILESYSTEM_ROOT=/data

# --- Observability ---
OTEL_EXPORTER=stdout
OTEL_ENDPOINT=
OTEL_SERVICE_NAME=registry-storage
OTEL_ENVIRONMENT=development
