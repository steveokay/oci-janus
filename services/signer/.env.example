# --- Server ---
GRPC_ADDR=:50051
HTTP_ADDR=:8080
LOG_LEVEL=info
LOG_FORMAT=json

# --- mTLS (required) ---
MTLS_CA_CERT_PATH=/certs/ca.crt
MTLS_CERT_PATH=/certs/signer.crt
MTLS_KEY_PATH=/certs/signer.key

# --- Observability ---
OTEL_EXPORTER=stdout
OTEL_ENDPOINT=
OTEL_SERVICE_NAME=registry-signer
OTEL_ENVIRONMENT=development

# --- Signing key (required for env backend) ---
# Generate with: openssl ecparam -name prime256v1 -genkey -noout | openssl pkcs8 -topk8 -nocrypt | base64 -w0
SIGNER_KEY_BACKEND=env
SIGNER_COSIGN_PRIVATE_KEY=<base64-encoded PEM PKCS8 ECDSA P-256 private key>
SIGNER_COSIGN_PUBLIC_KEY=<base64-encoded PEM PKIX ECDSA P-256 public key>

# --- Vault backend (if SIGNER_KEY_BACKEND=vault) ---
# VAULT_ADDR=https://vault:8200
# VAULT_TOKEN=
# VAULT_COSIGN_PATH=secret/cosign

# --- KMS backends ---
# SIGNER_KMS_ARN=arn:aws:kms:us-east-1:123456789:key/...      (awskms)
# SIGNER_KMS_RESOURCE_ID=projects/my-proj/locations/...       (gcpkms)
# SIGNER_KMS_VAULT_URL=https://myvault.vault.azure.net        (azurekms)
# SIGNER_KMS_KEY_NAME=my-cosign-key                           (azurekms)

# --- Database (SEC-015) ---
# Required in production for durable signature persistence.
# Without this the signer falls back to an in-memory store and all signature
# records are lost on restart (replicas also have independent stores).
# sslmode=require is mandatory; sslmode=disable is rejected at startup.
SIGNER_DB_DSN=postgres://signer:changeme@localhost:5432/registry_signer?sslmode=require
