# --- Server ---
GRPC_ADDR=:50051
HTTP_ADDR=:8080
LOG_LEVEL=info
LOG_FORMAT=json

# --- mTLS — production fail-safe (REDESIGN-001 Q-004 / Phase 1.2). Set to "false" only in local dev. ---
MTLS_REQUIRED=true
MTLS_CA_CERT_PATH=/certs/ca.crt
MTLS_CERT_PATH=/certs/audit.crt
MTLS_KEY_PATH=/certs/audit.key

# --- Observability ---
OTEL_EXPORTER=stdout
OTEL_ENDPOINT=
OTEL_SERVICE_NAME=registry-audit
OTEL_ENVIRONMENT=development

# --- Database ---
DB_DSN=postgres://audit:secret@postgres:5432/registry_audit?sslmode=require
DB_MAX_CONNS=20

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# --- Retention ---
# How many days to keep audit events (default: 365)
AUDIT_RETENTION_DAYS=365

# --- Trusted gateway ---
# IP of the gateway that sets X-Forwarded-For; used to extract real actor IP
TRUSTED_GATEWAY_IP=
