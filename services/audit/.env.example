# --- Server ---
GRPC_ADDR=:50051
HTTP_ADDR=:8080
LOG_LEVEL=info
LOG_FORMAT=json

# --- mTLS — production fail-safe (REDESIGN-001 Q-004 / Phase 1.2). Set to "false" only in local dev. ---
MTLS_REQUIRED=true
MTLS_CA_CERT_PATH=/certs/ca.crt
MTLS_CERT_PATH=/certs/audit.crt
MTLS_KEY_PATH=/certs/audit.key

# --- Observability ---
OTEL_EXPORTER=stdout
OTEL_ENDPOINT=
OTEL_SERVICE_NAME=registry-audit
OTEL_ENVIRONMENT=development

# --- Database ---
DB_DSN=postgres://audit:secret@postgres:5432/registry_audit?sslmode=require
DB_MAX_CONNS=20

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# --- Email notification channel (FUT-019 Phase 3) ---
# 32-byte AES-256-GCM KEK (64 hex chars) sealing email_transport_config secrets
# (resend_api_key / smtp_password). UNSET disables the email channel entirely:
# the transport RPCs return FAILED_PRECONDITION and the send loop idles.
# SET-but-not-64-hex-chars fails closed at startup (a bad KEK would silently
# corrupt secrets). Swept by rotate-kek (RED-FU-015).
NOTIFY_EMAIL_KEY_HEX=
# mTLS target for registry-auth.ResolveUserEmails — the dispatcher resolves email
# recipients through it. Empty disables email fan-out (bell channel unaffected).
AUTH_GRPC_ADDR=
# Optional public base URL used to build absolute CTA links in emails
# (e.g. https://registry.example.com). Empty → email links are app-relative.
PLATFORM_HOST=

# --- Retention ---
# How many days to keep audit events (default: 365)
AUDIT_RETENTION_DAYS=365

# --- Trusted gateway ---
# IP of the gateway that sets X-Forwarded-For; used to extract real actor IP
TRUSTED_GATEWAY_IP=

# --- rotate-kek subcommand only (RED-FU-015); not read by the server ---
# 32-byte AES-256 keys, hex-encoded (64 hex chars). Supplied at rotation time.
# See infra/runbooks/kek-rotation.md.
# KEK_OLD_HEX=
# KEK_NEW_HEX=
