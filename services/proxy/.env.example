# --- Server ---
GRPC_ADDR=:50055
HTTP_ADDR=:8084
LOG_LEVEL=info
LOG_FORMAT=json

# --- Database ---
DB_DSN=postgres://proxy:password@localhost:5432/proxy?sslmode=require
DB_MAX_CONNS=20

# --- Redis ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Upstream service addresses (gRPC) ---
AUTH_GRPC_ADDR=registry-auth:50051
STORAGE_GRPC_ADDR=registry-storage:50052

# --- Credential encryption ---
# 64-character hex string (32 bytes) — generate with: openssl rand -hex 32
CREDENTIAL_KEY_HEX=

# --- Upstream HTTP client ---
UPSTREAM_HTTP_TIMEOUT_SECS=30
UPSTREAM_MAX_RESPONSE_BYTES=21474836480

# --- mTLS — production fail-safe (REDESIGN-001 Q-004 / Phase 1.2). Set to "false" only in local dev. ---
MTLS_REQUIRED=true
MTLS_CA_CERT_PATH=/certs/ca.crt
MTLS_CERT_PATH=/certs/proxy.crt
MTLS_KEY_PATH=/certs/proxy.key

# --- Observability ---
OTEL_EXPORTER=stdout
OTEL_ENDPOINT=
OTEL_SERVICE_NAME=registry-proxy
OTEL_ENVIRONMENT=development
OTEL_SAMPLING_RATE=1.0

# --- rotate-kek subcommand only (RED-FU-015); not read by the server ---
# 32-byte AES-256 keys, hex-encoded (64 hex chars). Supplied at rotation time.
# See infra/runbooks/kek-rotation.md.
# KEK_OLD_HEX=
# KEK_NEW_HEX=
