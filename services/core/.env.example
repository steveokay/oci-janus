# --- Server ---
GRPC_ADDR=:50051
HTTP_ADDR=:8080
LOG_LEVEL=info
LOG_FORMAT=json

# --- mTLS (required) ---
MTLS_CA_CERT_PATH=/certs/ca.crt
MTLS_CERT_PATH=/certs/core.crt
MTLS_KEY_PATH=/certs/core.key

# --- Upstream service addresses ---
AUTH_GRPC_ADDR=registry-auth:50051
# Externally reachable URL returned in WWW-Authenticate realm (Docker clients must be able to reach this)
AUTH_REALM=http://localhost:8080/auth/token
METADATA_GRPC_ADDR=registry-metadata:50051
STORAGE_GRPC_ADDR=registry-storage:50051

# --- Redis (upload state) ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# --- Pull-activity tracking (FE-API-042) ---
# Probability that a successful manifest GET publishes a pull.image event.
# Range: [0.0, 1.0]. Default 1.0 (publish every pull).
#
# Reducing this loses FE-API-030 analytics precision (metric=pulls) proportionally.
# The FE-API-043 max_idle_days retention rule rides services/metadata's
# 24h-debounced last_pulled_at update, so its accuracy is preserved as long as
# this rate is > 0. Set to 0.0 to disable the publish entirely (analytics will
# return zeros and max_idle_days retention will stop tracking new pulls).
PULL_EVENT_SAMPLE_RATE=1.0

# --- Observability ---
OTEL_EXPORTER=stdout
OTEL_ENDPOINT=
OTEL_SERVICE_NAME=registry-core
OTEL_ENVIRONMENT=development
