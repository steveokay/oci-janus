# --- Server ---
GRPC_ADDR=:50051
HTTP_ADDR=:8080
LOG_LEVEL=info
LOG_FORMAT=json

# --- mTLS — production fail-safe (REDESIGN-001 Q-004 / Phase 1.2). Set to "false" only in local dev. ---
MTLS_REQUIRED=true
MTLS_CA_CERT_PATH=/certs/ca.crt
MTLS_CERT_PATH=/certs/gateway.crt
MTLS_KEY_PATH=/certs/gateway.key

# --- Observability ---
OTEL_EXPORTER=stdout
OTEL_ENDPOINT=
OTEL_SERVICE_NAME=registry-gateway
OTEL_ENVIRONMENT=development
