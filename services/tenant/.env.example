# --- Server ---
GRPC_ADDR=:50051
HTTP_ADDR=:8080
LOG_LEVEL=info
LOG_FORMAT=json

# --- mTLS (required) ---
MTLS_CA_CERT_PATH=/certs/ca.crt
MTLS_CERT_PATH=/certs/tenant.crt
MTLS_KEY_PATH=/certs/tenant.key

# --- Observability ---
OTEL_EXPORTER=stdout
OTEL_ENDPOINT=
OTEL_SERVICE_NAME=registry-tenant
OTEL_ENVIRONMENT=development
