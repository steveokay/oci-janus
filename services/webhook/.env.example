# --- Server ---
GRPC_ADDR=:50051
HTTP_ADDR=:8080
LOG_LEVEL=info
LOG_FORMAT=json

# --- mTLS — production fail-safe (REDESIGN-001 Q-004 / Phase 1.2). Set to "false" only in local dev. ---
MTLS_REQUIRED=true
MTLS_CA_CERT_PATH=/certs/ca.crt
MTLS_CERT_PATH=/certs/webhook.crt
MTLS_KEY_PATH=/certs/webhook.key

# --- Observability ---
OTEL_EXPORTER=stdout
OTEL_ENDPOINT=
OTEL_SERVICE_NAME=registry-webhook
OTEL_ENVIRONMENT=development

# --- Database ---
DB_DSN=postgres://webhook:secret@postgres:5432/registry_webhook?sslmode=require
DB_MAX_CONNS=20

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# --- Credentials ---
# 32-byte AES key for encrypting HMAC secrets at rest.
# Generate: openssl rand -hex 32
CREDENTIAL_KEY_HEX=

# --- Delivery ---
DELIVERY_POLL_INTERVAL_SECS=5
DELIVERY_TIMEOUT_SECS=30

# --- rotate-kek subcommand only (RED-FU-015); not read by the server ---
# 32-byte AES-256 keys, hex-encoded (64 hex chars). Supplied at rotation time.
# See infra/runbooks/kek-rotation.md.
# KEK_OLD_HEX=
# KEK_NEW_HEX=
