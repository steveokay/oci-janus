# --- Server ---
GRPC_ADDR=:50051
HTTP_ADDR=:8080
LOG_LEVEL=info
LOG_FORMAT=json

# --- mTLS (required) ---
MTLS_CA_CERT_PATH=/certs/ca.crt
MTLS_CERT_PATH=/certs/auth.crt
MTLS_KEY_PATH=/certs/auth.key

# --- Database ---
DB_DSN=postgres://auth:password@localhost:5432/registry_auth?sslmode=require
DB_MAX_CONNS=20
DB_MIN_CONNS=2

# --- Redis ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# --- JWT signing (RS256) ---
JWT_PRIVATE_KEY_B64=   # base64-encoded PEM, required
JWT_PUBLIC_KEY_B64=    # base64-encoded PEM, required
JWT_KEY_ID=            # kid for JWKS rotation

# --- Observability ---
OTEL_EXPORTER=stdout
OTEL_ENDPOINT=
OTEL_SERVICE_NAME=registry-auth
OTEL_ENVIRONMENT=development
