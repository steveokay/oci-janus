# registry-management — copy to .env.local and fill in values
# Never commit .env.local or any file containing real secrets.

# HTTP listen address (default :8085)
HTTP_ADDR=:8085

# gRPC addresses of upstream services
AUTH_GRPC_ADDR=localhost:50051
METADATA_GRPC_ADDR=localhost:50053

# Optional gRPC clients — leave empty to disable the corresponding routes.
# SCANNER_GRPC_ADDR enables FE-API-018 (scan policies) and FE-API-019
# (compliance reports). Empty: routes return 404 "route disabled".
SCANNER_GRPC_ADDR=
# SIGNER_GRPC_ADDR enables FE-API-003 signature lookups.
SIGNER_GRPC_ADDR=
# WEBHOOK_GRPC_ADDR enables FE-API-021..024 webhook routes.
WEBHOOK_GRPC_ADDR=
# TENANT_GRPC_ADDR enables /api/v1/admin/tenants + /api/v1/workspace/me.
TENANT_GRPC_ADDR=

# CORS — must match the frontend origin exactly; never use *
# Dev: http://localhost:5173  |  Prod: https://registry.yourdomain.io
CORS_ALLOWED_ORIGIN=http://localhost:5173

# mTLS — leave blank for local dev (insecure fallback used)
MTLS_CA_CERT_PATH=
MTLS_CERT_PATH=
MTLS_KEY_PATH=

# Logging
LOG_FORMAT=text
LOG_LEVEL=info

# OpenTelemetry
OTEL_EXPORTER=stdout
OTEL_ENDPOINT=
OTEL_SERVICE_NAME=registry-management
OTEL_ENVIRONMENT=development
OTEL_SAMPLING_RATE=1.0
