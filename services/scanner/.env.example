# --- Server ---
GRPC_ADDR=:50051
HTTP_ADDR=:8080
LOG_LEVEL=info
LOG_FORMAT=json

# --- mTLS (required) ---
MTLS_CA_CERT_PATH=/certs/ca.crt
MTLS_CERT_PATH=/certs/scanner.crt
MTLS_KEY_PATH=/certs/scanner.key

# --- Observability ---
OTEL_EXPORTER=stdout
OTEL_ENDPOINT=
OTEL_SERVICE_NAME=registry-scanner
OTEL_ENVIRONMENT=development

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# --- Upstream gRPC services ---
METADATA_GRPC_ADDR=registry-metadata:50051
STORAGE_GRPC_ADDR=registry-storage:50051

# --- Scanner plugin ---
# Path to the scanner binary (e.g. /plugins/trivy-wrapper)
SCANNER_PLUGIN_PATH=
# SHA256 hex checksum of the plugin binary — service refuses to start on mismatch
SCANNER_PLUGIN_CHECKSUM=
# Number of concurrent scan workers (default: 4)
SCANNER_WORKER_COUNT=4
# Per-job timeout in seconds (default: 600)
SCANNER_JOB_TIMEOUT_SECS=600
