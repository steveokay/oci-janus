# Binaries
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Go workspace sum (auto-generated)
go.work.sum

# Test output
*.out
coverage.html
coverage.txt

# Build artifacts
dist/
*.test

# Environment files — never commit real secrets
.env
.env.local
.env.*.local
!.env.example

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.swp
*.swo

# Frontend
ui/node_modules/
ui/dist/
ui/.env
ui/.env.local

# Terraform
infra/terraform/.terraform/
infra/terraform/*.tfstate
infra/terraform/*.tfstate.backup
infra/terraform/*.tfvars
!infra/terraform/*.tfvars.example

# TLS dev certs (generated by make dev-certs)
certs/

# Local developer notes (may contain personal key snippets)
local-setup.md

# Proto generated — committed intentionally, but exclude local overrides
# proto/gen/go — DO NOT add to gitignore, generated stubs are committed
