{
  "info": {
    "_postman_id": "8a7b3c12-9e4f-4a1d-9c81-1c2a3b4c5d6e",
    "name": "registry-management API",
    "description": "All public HTTP endpoints exposed by services/management (the BFF for the dashboard, CLI, and Terraform). Also covers the auth-side HTTP routes the gateway exposes under the same prefix (/api/v1/login, /logout, /token/refresh, /users, /apikeys). See docs/postman/README.md for env setup.\n\n**Auth flow:** run *Auth → Login* first. The collection's test script writes the returned JWT to {{token}} so all subsequent requests use it via the collection-level Bearer auth.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {"type": "text/javascript", "exec": [""]}
    }
  ],
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:8091", "type": "string"},
    {"key": "token", "value": "", "type": "string"},
    {"key": "tenantId", "value": "", "type": "string"},
    {"key": "org", "value": "dev", "type": "string"},
    {"key": "repo", "value": "alpine", "type": "string"},
    {"key": "tag", "value": "3.20", "type": "string"},
    {"key": "assignmentId", "value": "", "type": "string"},
    {"key": "userId", "value": "", "type": "string"},
    {"key": "apiKeyId", "value": "", "type": "string"},
    {"key": "webhookId", "value": "", "type": "string"}
  ],
