    {
      "name": "Auth",
      "description": "Endpoints served by registry-auth and routed by the gateway under the same /api/v1 prefix.",
      "item": [
        {
          "name": "POST /api/v1/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Capture the JWT into the {{token}} env variable so subsequent requests authenticate automatically.",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body.token) pm.collectionVariables.set('token', body.token);",
                  "  if (body.user_id) pm.collectionVariables.set('userId', body.user_id);",
                  "  if (body.tenant_id) pm.collectionVariables.set('tenantId', body.tenant_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {"type": "noauth"},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_id\": \"{{tenantId}}\",\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {"raw": "{{baseUrl}}/api/v1/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "login"]}
          }
        },
        {
          "name": "POST /api/v1/logout",
          "request": {
            "method": "POST",
            "url": {"raw": "{{baseUrl}}/api/v1/logout", "host": ["{{baseUrl}}"], "path": ["api", "v1", "logout"]}
          }
        },
        {
          "name": "POST /api/v1/token/refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body.token) pm.collectionVariables.set('token', body.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {"raw": "{{baseUrl}}/api/v1/token/refresh", "host": ["{{baseUrl}}"], "path": ["api", "v1", "token", "refresh"]}
          }
        },
        {
          "name": "POST /api/v1/users (admin only)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser\",\n  \"password\": \"NewUser1234!\",\n  \"email\": \"newuser@example.com\",\n  \"tenant_id\": \"{{tenantId}}\"\n}"
            },
            "url": {"raw": "{{baseUrl}}/api/v1/users", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users"]}
          }
        }
      ]
    },
