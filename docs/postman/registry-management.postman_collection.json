    {
      "name": "Webhooks",
      "description": "FE-API-021..024. Routes return 404 'route disabled' when WEBHOOK_GRPC_ADDR is unset on the management service. Create/update/delete/rotate/test require an admin role on some org in the tenant.",
      "item": [
        {
          "name": "GET /api/v1/webhooks",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/v1/webhooks", "host": ["{{baseUrl}}"], "path": ["api", "v1", "webhooks"]}
          }
        },
        {
          "name": "POST /api/v1/webhooks",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body.endpoint_id) pm.collectionVariables.set('webhookId', body.endpoint_id);",
                  "}"
