              "mode": "raw",
              "raw": "{\n  \"url\": \"https://hooks.example.com/registry\",\n  \"events\": [\"push.completed\", \"scan.completed\"]\n}"
            },
            "url": {"raw": "{{baseUrl}}/api/v1/webhooks", "host": ["{{baseUrl}}"], "path": ["api", "v1", "webhooks"]}
          }
        },
        {
