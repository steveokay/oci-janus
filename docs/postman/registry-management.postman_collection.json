              "mode": "raw",
              "raw": "{\n  \"active\": false\n}"
            },
            "url": {"raw": "{{baseUrl}}/api/v1/webhooks/{{webhookId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "webhooks", "{{webhookId}}"]}
          }
        },
        {
          "name": "DELETE /api/v1/webhooks/{id}",
