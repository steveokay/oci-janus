{
  "info": {
    "_postman_id": "8a7b3c12-9e4f-4a1d-9c81-1c2a3b4c5d6e",
    "name": "registry-management API",
    "description": "All public HTTP endpoints exposed by services/management (the BFF for the dashboard, CLI, and Terraform). Also covers the auth-side HTTP routes the gateway exposes under the same prefix (/api/v1/login, /logout, /token/refresh, /users, /apikeys). See docs/postman/README.md for env setup.\n\n**Auth flow:** run *Auth → Login* first. The collection's test script writes the returned JWT to {{token}} so all subsequent requests use it via the collection-level Bearer auth.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {"type": "text/javascript", "exec": [""]}
    }
  ],
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:8091", "type": "string"},
    {"key": "token", "value": "", "type": "string"},
    {"key": "tenantId", "value": "", "type": "string"},
    {"key": "org", "value": "dev", "type": "string"},
    {"key": "repo", "value": "alpine", "type": "string"},
    {"key": "tag", "value": "3.20", "type": "string"},
    {"key": "assignmentId", "value": "", "type": "string"},
    {"key": "userId", "value": "", "type": "string"},
    {"key": "apiKeyId", "value": "", "type": "string"},
    {"key": "webhookId", "value": "", "type": "string"}
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /healthz",
          "request": {
            "auth": {"type": "noauth"},
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/healthz", "host": ["{{baseUrl}}"], "path": ["healthz"]}
          }
        }
      ]
    },
    {
      "name": "Auth",
      "description": "Endpoints served by registry-auth and routed by the gateway under the same /api/v1 prefix.",
      "item": [
        {
          "name": "POST /api/v1/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Capture the JWT into the {{token}} env variable so subsequent requests authenticate automatically.",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body.token) pm.collectionVariables.set('token', body.token);",
                  "  if (body.user_id) pm.collectionVariables.set('userId', body.user_id);",
                  "  if (body.tenant_id) pm.collectionVariables.set('tenantId', body.tenant_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {"type": "noauth"},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_id\": \"{{tenantId}}\",\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {"raw": "{{baseUrl}}/api/v1/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "login"]}
          }
        },
        {
          "name": "POST /api/v1/logout",
          "request": {
            "method": "POST",
            "url": {"raw": "{{baseUrl}}/api/v1/logout", "host": ["{{baseUrl}}"], "path": ["api", "v1", "logout"]}
          }
        },
        {
          "name": "POST /api/v1/token/refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body.token) pm.collectionVariables.set('token', body.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {"raw": "{{baseUrl}}/api/v1/token/refresh", "host": ["{{baseUrl}}"], "path": ["api", "v1", "token", "refresh"]}
          }
        },
        {
          "name": "POST /api/v1/users (admin only)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser\",\n  \"password\": \"NewUser1234!\",\n  \"email\": \"newuser@example.com\",\n  \"tenant_id\": \"{{tenantId}}\"\n}"
            },
            "url": {"raw": "{{baseUrl}}/api/v1/users", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users"]}
          }
        }
      ]
    },
